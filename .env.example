# Norte — environment. Copy this to `.env` and fill it in. NEVER commit real
# values: `.env` is gitignored, and the brapi token must stay off git/chat (§7).
#
#   cp .env.example .env
#
# Both Prisma (via dotenv in prisma.config.ts) and Next.js read `.env`, so a
# single file covers the CLI (migrations) and the running app.

# SQLite database file. On the server use an ABSOLUTE path so it's stable no
# matter the working directory. This file holds your financial data — it is
# gitignored, must be backed up (Litestream, later), and never committed.
# Dev (Windows) example:   file:./dev.db
# Server (Ubuntu) example: file:/home/ubuntu/norte/prod.db
DATABASE_URL="file:./dev.db"

# brapi token for quote/dividend sync. Optional — without it the app falls back
# to manual prices. Free token at https://brapi.dev.
BRAPI_TOKEN=""
