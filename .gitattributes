# Shell scripts and the systemd unit must keep LF line endings so they run on the
# Linux EC2 box, even when the repo is checked out on Windows (CRLF would break
# the script shebang / unit parsing).
*.sh text eol=lf
*.service text eol=lf

# Windows batch / PowerShell scripts need CRLF.
*.bat text eol=crlf
*.ps1 text eol=crlf
